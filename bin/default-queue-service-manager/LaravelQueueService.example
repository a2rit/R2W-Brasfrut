<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
        <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
            <section name="LaravelQueueService.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false"/>
        </sectionGroup>
    </configSections>
    <startup>

    <supportedRuntime version="v2.0.50727"/></startup>
    <applicationSettings>
        <LaravelQueueService.Properties.Settings>
            <setting name="service_name" serializeAs="String">
                <value>LaravelQueueService</value>
            </setting>
            <setting name="service_display_name" serializeAs="String">
                <value>Laravel Queue Service</value>
            </setting>
            <setting name="service_start_type" serializeAs="String">
                <value>Automatic</value>
            </setting>
            <setting name="php_path" serializeAs="String">
                <value>php.exe</value>
            </setting>
            <setting name="laravel_base_path" serializeAs="String">
                <value>LaravelProject</value>
            </setting>
            <setting name="service_description" serializeAs="String">
                <value>Laravel Queue Work</value>
            </setting>
            <setting name="queue_drive" serializeAs="String">
                <value>database</value>
            </setting>
            <setting name="queue_work_arguments" serializeAs="String">
                <value>--queue=very-high,high,default,low,very-low -vvv</value>
            </setting>
            <setting name="log_file_name" serializeAs="String">
                <value>service</value>
            </setting>
            <setting name="restart_command" serializeAs="String">
                <value>queue:restart</value>
            </setting>
        </LaravelQueueService.Properties.Settings>
    </applicationSettings>
</configuration>
